{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0",
      "protobufjs": ">=7.5.5",
      "vite": ">=7.3.2",
      "minimatch": ">=3.1.4",
      "brace-expansion": ">=1.1.13",
      "flatted": ">=3.4.2",
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.13",
      "ajv": ">=6.14.0",
      "yaml": ">=2.8.3",
      "path-to-regexp": ">=8.4.2"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "@sentry/cli",
      "sharp",
      "protobufjs",
      "unrs-resolver"
    ]
  },
  "lint-staged": {
    "packages/cli/src/**/*.ts": [
      "bash -c 'cd packages/cli && npx tsc --noEmit'"
    ],
    "packages/core/src/**/*.ts": [
      "bash -c 'cd packages/core && npx tsc --noEmit'"
    ],
    "packages/ai-sdk/src/**/*.ts": [
      "bash -c 'cd packages/ai-sdk && npx tsc --noEmit'"
    ],
    "packages/web/src/**/*.{ts,tsx}": [
      "bash -c 'cd packages/web && npx eslint --max-warnings 0'"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vite": "^7.3.2"
  }
}
